<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.KampanyaRadari" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@color/near_black</item>
        <item name="android:statusBarColor">@color/near_black</item>
        <item name="android:navigationBarColor">@color/near_black</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Theme.KampanyaRadari.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/near_black</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.KampanyaRadari</item>
    </style>
</resources>
